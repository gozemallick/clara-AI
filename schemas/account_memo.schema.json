{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Clara Account Memo",
  "type": "object",
  "required": [
    "account_id",
    "business_hours",
    "services_supported",
    "emergency_definition",
    "emergency_routing_rules",
    "non_emergency_routing_rules",
    "call_transfer_rules",
    "integration_constraints",
    "after_hours_flow_summary",
    "office_hours_flow_summary",
    "questions_or_unknowns",
    "version"
  ],
  "properties": {
    "account_id": {
      "type": "string"
    },
    "company_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "business_hours": {
      "type": "object",
      "required": [
        "days",
        "start",
        "end",
        "timezone"
      ],
      "properties": {
        "days": {
          "type": [
            "string",
            "null"
          ]
        },
        "start": {
          "type": [
            "string",
            "null"
          ]
        },
        "end": {
          "type": [
            "string",
            "null"
          ]
        },
        "timezone": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "office_address": {
      "type": [
        "string",
        "null"
      ]
    },
    "services_supported": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "emergency_definition": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "emergency_routing_rules": {
      "type": "object",
      "required": [
        "primary_contact",
        "secondary_contact",
        "transfer_order",
        "fallback"
      ],
      "properties": {
        "primary_contact": {
          "type": [
            "string",
            "null"
          ]
        },
        "secondary_contact": {
          "type": [
            "string",
            "null"
          ]
        },
        "transfer_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallback": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "non_emergency_routing_rules": {
      "type": "object",
      "required": [
        "routing_summary",
        "intake_required_fields",
        "follow_up_window"
      ],
      "properties": {
        "routing_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "intake_required_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "follow_up_window": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "call_transfer_rules": {
      "type": "object",
      "required": [
        "timeout_seconds",
        "retries",
        "transfer_fail_message"
      ],
      "properties": {
        "timeout_seconds": {
          "type": [
            "integer",
            "null"
          ]
        },
        "retries": {
          "type": [
            "integer",
            "null"
          ]
        },
        "transfer_fail_message": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "integration_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "after_hours_flow_summary": {
      "type": "string"
    },
    "office_hours_flow_summary": {
      "type": "string"
    },
    "questions_or_unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "enum": [
        "v1",
        "v2"
      ]
    }
  }
}


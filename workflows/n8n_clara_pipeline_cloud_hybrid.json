        "options": {}
      },
      "id": "set_github_config",
      "name": "Set GitHub Config",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        420,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const cfg = $json;\n\nif (String(cfg.token || '').startsWith('REPLACE_')) {\n  throw new Error('Replace REPLACE_WITH_GITHUB_PAT in Set GitHub Config before running.');\n}\n\nconst dispatchedAt = new Date().toISOString();\n\nconst dispatch = await this.helpers.httpRequest({\n  method: 'POST',\n  url: `https://api.github.com/repos/${cfg.owner}/${cfg.repo}/actions/workflows/${cfg.workflow_id}/dispatches`,\n  headers: {\n    Authorization: `Bearer ${cfg.token}`,\n    Accept: 'application/vnd.github+json',\n    'X-GitHub-Api-Version': '2022-11-28'\n  },\n  body: { ref: cfg.ref },\n  json: true,\n  resolveWithFullResponse: true,\n  simple: false\n});\n\nreturn [\n  {\n    json: {\n      ...cfg,\n      dispatch_status_code: dispatch.statusCode,\n      dispatched: dispatch.statusCode === 204,\n      dispatched_at_utc: dispatchedAt\n    }\n  }\n];"
      },
      "id": "dispatch_github_action",
      "name": "Dispatch GitHub Action",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        320
      ]
    },
    {
      "parameters": {
        "amount": 15
      },
      "id": "wait_15_seconds",
      "name": "Wait 15 Seconds",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [
        940,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const cfg = $json;\n\nconst runsResp = await this.helpers.httpRequest({\n  method: 'GET',\n  url: `https://api.github.com/repos/${cfg.owner}/${cfg.repo}/actions/workflows/${cfg.workflow_id}/runs?branch=${encodeURIComponent(cfg.ref)}&event=workflow_dispatch&per_page=20`,\n  headers: {\n    Authorization: `Bearer ${cfg.token}`,\n    Accept: 'application/vnd.github+json',\n    'X-GitHub-Api-Version': '2022-11-28'\n  },\n  json: true\n});\n\nconst runs = Array.isArray(runsResp.workflow_runs) ? runsResp.workflow_runs : [];\nconst dispatchedAtMs = Date.parse(cfg.dispatched_at_utc || '1970-01-01T00:00:00Z');\nconst run = runs.find((r) => Date.parse(r.created_at) >= dispatchedAtMs - 5000) || runs[0] || null;\n\nreturn [\n  {\n    json: {\n      ...cfg,\n      run_id: run ? run.id : null,\n      run_status: run ? run.status : null,\n      run_conclusion: run ? run.conclusion : null,\n      run_url: run ? run.html_url : null\n    }\n  }\n];"
      },
      "id": "check_latest_run",
      "name": "Check Latest Run",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1180,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const j = $json;\n\nif (!j.run_id) {\n  return [\n    {\n      json: {\n        ...j,\n        artifact_archive_download_url: null\n      }\n    }\n  ];\n}\n\nconst artifactsResp = await this.helpers.httpRequest({\n  method: 'GET',\n  url: `https://api.github.com/repos/${j.owner}/${j.repo}/actions/runs/${j.run_id}/artifacts?per_page=100`,\n  headers: {\n    Authorization: `Bearer ${j.token}`,\n    Accept: 'application/vnd.github+json',\n    'X-GitHub-Api-Version': '2022-11-28'\n  },\n  json: true\n});\n\nconst artifact = (artifactsResp.artifacts || []).find((a) => a.name === j.artifact_name) || null;\n\nreturn [\n  {\n    json: {\n      ...j,\n      artifact_archive_download_url: artifact ? artifact.archive_download_url : null\n    }\n  }\n];"
      },
      "id": "get_artifact_info",
      "name": "Get Artifact Info",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1420,
        320
      ]
    },

              "type": "string"
            },
            {
              "id": "cfg-ref",
              "name": "ref",
              "value": "main",
              "type": "string"
            },
            {
              "id": "cfg-token",
              "name": "token",
              "value": "REPLACE_WITH_GITHUB_PAT",
              "type": "string"
            },
            {
              "id": "cfg-artifact",
              "name": "artifact_name",
              "value": "clara-pipeline-outputs",
              "type": "string"
